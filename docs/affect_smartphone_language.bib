  author = {Sun, Tiezhu and Allix, Kevin and Kim, Kisub and Zhou, Xin and Kim, Dongsun and Lo, David and Bissyand{\'e}, Tegawend{\'e} F. and Klein, Jacques},
  year = {2022},
